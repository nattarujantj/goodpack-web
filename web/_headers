# Entry point files — never cache so new deploys are always picked up
/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/flutter_bootstrap.js
  Cache-Control: no-cache, no-store, must-revalidate

/flutter_service_worker.js
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.json
  Cache-Control: no-cache, no-store, must-revalidate

# Content-hashed assets — safe to cache long-term
/main.dart.js
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable
